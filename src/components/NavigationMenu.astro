---
import type { NavItem, CategoryNavItem } from '../utils/contentLoader';

interface Props {
  items: NavItem[];
  currentUrl: string;
}

const { items, currentUrl } = Astro.props;

function isActive(url: string): boolean {
  return url === currentUrl;
}

// Req 3.5 — detect CategoryNavItem: has children where at least one child has children (sections)
function isCategoryItem(item: NavItem): item is CategoryNavItem {
  return !!(item.children && item.children.some((child) => child.children && child.children.length > 0));
}

// Req 5.1 — check if any section within a category is the active URL
function isCategoryActive(item: NavItem): boolean {
  if (!item.children) return false;
  return item.children.some(
    (chapter) =>
      isActive(chapter.url) ||
      (chapter.children?.some((section) => isActive(section.url)) ?? false)
  );
}
---

<nav
  role="navigation"
  aria-label="Navegação do livro"
  id="navigation-menu"
  class="nav-menu"
>
  <!-- Mobile hamburger button -->
  <button
    id="nav-toggle"
    class="nav-toggle"
    aria-expanded="false"
    aria-controls="nav-panel"
    aria-label="Abrir menu de navegação"
  >
    <span class="hamburger-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <!-- Navigation panel -->
  <div id="nav-panel" class="nav-panel" aria-hidden="true">
    <ul class="nav-list" role="list">
      <li class="nav-chapter nav-home">
        <a
          href={`${import.meta.env.BASE_URL}`}
          class:list={['nav-chapter-link', { 'nav-active': currentUrl === '/' }]}
          aria-current={currentUrl === '/' ? 'page' : undefined}
        >
          <span class="nav-item-title">🏠 Home</span>
        </a>
      </li>
      {items.map((item) =>
        isCategoryItem(item) ? (
          /* ── Category group (Req 3.1, 3.2, 3.4, 4.1, 4.8, 7.1, 7.3, 7.4) ── */
          <li
            class:list={['nav-category', { 'nav-category--active': isCategoryActive(item) }]}
            data-category-slug={item.slug}
          >
            <button
              class="nav-category-btn"
              aria-expanded="true"
              aria-controls={`nav-cat-${item.slug}`}
              aria-label={item.title || 'Capítulos sem categoria'}
            >
              <span class="nav-category-label">{item.title}</span>
              <span class="nav-category-chevron" aria-hidden="true">▾</span>
            </button>
            <ul id={`nav-cat-${item.slug}`} class="nav-chapter-list" role="list">
              {item.children.map((chapter) => (
                <li class="nav-chapter">
                  {chapter.children && chapter.children.length > 0 ? (
                    <span
                      class:list={['nav-chapter-label', { 'nav-active': isActive(chapter.url) }]}
                    >
                      <span class="nav-item-title">{chapter.title}</span>
                    </span>
                  ) : (
                    <a
                      href={`${import.meta.env.BASE_URL}${chapter.url}`}
                      class:list={['nav-chapter-link', { 'nav-active': isActive(chapter.url) }]}
                      aria-current={isActive(chapter.url) ? 'page' : undefined}
                    >
                      <span class="nav-item-title">{chapter.title}</span>
                    </a>
                  )}
                  {chapter.children && chapter.children.length > 0 && (
                    <ul class="nav-section-list" role="list">
                      {chapter.children.map((section) => (
                        <li class="nav-section">
                          <a
                            href={`${import.meta.env.BASE_URL}${section.url}`}
                            class:list={['nav-section-link', { 'nav-active': isActive(section.url) }]}
                            aria-current={isActive(section.url) ? 'page' : undefined}
                            data-nav-url={section.url}
                            onclick="smoothScrollToSection(event, this)"
                          >
                            <span class="nav-item-title">{section.title}</span>
                            <span
                              class="nav-visited-icon"
                              aria-hidden="true"
                              data-visited-slug={section.slug}
                              style="display:none"
                            >✓</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </li>
        ) : (
          /* ── Plain chapter item (Req 3.5 — backward compat) ── */
          <li class="nav-chapter">
            {item.children && item.children.length > 0 ? (
              <span
                class:list={['nav-chapter-label', { 'nav-active': isActive(item.url) }]}
              >
                <span class="nav-item-title">{item.title}</span>
              </span>
            ) : (
              <a
                href={`${import.meta.env.BASE_URL}${item.url}`}
                class:list={['nav-chapter-link', { 'nav-active': isActive(item.url) }]}
                aria-current={isActive(item.url) ? 'page' : undefined}
              >
                <span class="nav-item-title">{item.title}</span>
              </a>
            )}
            {item.children && item.children.length > 0 && (
              <ul class="nav-section-list" role="list">
                {item.children.map((section) => (
                  <li class="nav-section">
                    <a
                      href={`${import.meta.env.BASE_URL}${section.url}`}
                      class:list={['nav-section-link', { 'nav-active': isActive(section.url) }]}
                      aria-current={isActive(section.url) ? 'page' : undefined}
                      data-nav-url={section.url}
                      onclick="smoothScrollToSection(event, this)"
                    >
                      <span class="nav-item-title">{section.title}</span>
                      <span
                        class="nav-visited-icon"
                        aria-hidden="true"
                        data-visited-slug={section.slug}
                        style="display:none"
                      >✓</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        )
      )}
    </ul>
  </div>
</nav>

<script>
  // Smooth scroll to section when clicking a nav item
  function smoothScrollToSection(event: MouseEvent, anchor: HTMLAnchorElement) {
    const href = anchor.getAttribute('href');
    if (!href) return;

    // Only intercept hash-based or same-page navigation
    const url = new URL(href, window.location.href);
    if (url.pathname === window.location.pathname && url.hash) {
      event.preventDefault();
      const target = document.querySelector(url.hash);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    }
  }

  // Expose for inline onclick
  (window as any).smoothScrollToSection = smoothScrollToSection;

  // Mobile hamburger toggle
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-panel');

  if (toggle && panel) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      panel.setAttribute('aria-hidden', String(expanded));
      panel.classList.toggle('nav-panel--open', !expanded);
    });
  }

  // Mark visited sections from localStorage (Req 8.2, 8.3)
  function updateVisitedIndicators() {
    try {
      const raw = localStorage.getItem('ibbook_progress');
      if (!raw) return;

      const progress = JSON.parse(raw) as { visitedSections?: string[] };
      const visited = new Set(progress.visitedSections ?? []);

      document.querySelectorAll<HTMLElement>('[data-visited-slug]').forEach((el) => {
        const slug = el.getAttribute('data-visited-slug');
        if (slug && visited.has(slug)) {
          el.style.display = 'inline';
        }
      });
    } catch {
      // localStorage unavailable or corrupted — silently ignore
    }
  }

  updateVisitedIndicators();

  // ── Category collapse/expand (Req 4.2–4.8) ──────────────────────────────

  const NAV_CATEGORIES_KEY = 'ibbook_nav_categories';

  // Load persisted collapse state; returns {} on any failure (Req 4.7)
  function loadCategoryState(): Record<string, boolean> {
    try {
      const raw = localStorage.getItem(NAV_CATEGORIES_KEY);
      if (!raw) return {};
      return JSON.parse(raw) as Record<string, boolean>;
    } catch {
      return {};
    }
  }

  // Persist collapse state (Req 4.6)
  function saveCategoryState(state: Record<string, boolean>): void {
    try {
      localStorage.setItem(NAV_CATEGORIES_KEY, JSON.stringify(state));
    } catch {
      // localStorage unavailable — silently ignore (Req 4.7)
    }
  }

  // Apply collapsed/expanded state to a category <li> and its <button>
  function applyCollapseState(li: HTMLElement, collapsed: boolean): void {
    const btn = li.querySelector<HTMLButtonElement>('.nav-category-btn');
    if (!btn) return;
    li.classList.toggle('nav-category--collapsed', collapsed);
    btn.setAttribute('aria-expanded', String(!collapsed));
  }

  // Initialise all category groups on page load
  function initCategoryCollapse(): void {
    const state = loadCategoryState();

    // Find the slug of the category that contains the active chapter/section
    let activeSlug: string | null = null;
    const activeEl = document.querySelector<HTMLElement>(
      '.nav-section-link.nav-active, .nav-chapter-link.nav-active'
    );
    if (activeEl) {
      const categoryLi = activeEl.closest<HTMLElement>('.nav-category');
      if (categoryLi) {
        activeSlug = categoryLi.getAttribute('data-category-slug');
      }
    }

    document.querySelectorAll<HTMLElement>('.nav-category').forEach((li) => {
      const slug = li.getAttribute('data-category-slug') ?? '';
      // Req 4.5 — active category is always expanded, overrides persisted state
      const collapsed = slug === activeSlug ? false : (state[slug] ?? false);
      applyCollapseState(li, collapsed);
    });
  }

  // Wire up click handlers for all category buttons
  function bindCategoryButtons(): void {
    document.querySelectorAll<HTMLButtonElement>('.nav-category-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const li = btn.closest<HTMLElement>('.nav-category');
        if (!li) return;
        const slug = li.getAttribute('data-category-slug') ?? '';
        // Req 4.2 — toggle collapse state
        const nowCollapsed = btn.getAttribute('aria-expanded') === 'true';
        applyCollapseState(li, nowCollapsed);

        // Persist updated state (Req 4.6)
        const state = loadCategoryState();
        state[slug] = nowCollapsed;
        saveCategoryState(state);
      });
    });
  }

  initCategoryCollapse();
  bindCategoryButtons();

  // Scroll the active nav item into view within the nav panel
  function scrollActiveItemIntoView() {
    const activeLink = document.querySelector<HTMLElement>('.nav-section-link.nav-active, .nav-chapter-link.nav-active');
    if (!activeLink) return;
    const navPanel = document.getElementById('nav-panel');
    if (!navPanel) return;
    activeLink.scrollIntoView({ block: 'nearest', inline: 'nearest' });
  }

  scrollActiveItemIntoView();
</script>

<style>
  /* ── Base nav container ── */
  .nav-menu {
    position: relative;
  }

  /* ── Hamburger button (hidden on desktop) ── */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--color-text, #1a1a2e);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text, #1a1a2e);
    transition: background 150ms ease;
  }

  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 10%, transparent);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 20px;
  }

  .hamburger-icon span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  /* ── Nav panel ── */
  .nav-panel {
    width: 100%;
  }

  /* ── Nav list ── */
  .nav-list,
  .nav-section-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Chapter items ── */
  .nav-chapter {
    margin-bottom: 0.25rem;
  }

  .nav-chapter-link,
  .nav-chapter-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text, #1a1a2e);
    text-decoration: none;
    transition: background 150ms ease, color 150ms ease;
  }

  .nav-chapter-label {
    cursor: default;
    opacity: 0.75;
  }

  .nav-chapter-link:hover,
  .nav-chapter-link:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 8%, transparent);
    color: var(--color-primary, #2563eb);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* ── Section items ── */
  .nav-section-list {
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--color-text, #1a1a2e) 15%, transparent);
    margin: 0.125rem 0 0.25rem 0.75rem;
  }

  .nav-section-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.375rem 0.625rem;
    border-radius: 4px;
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-text, #1a1a2e) 80%, transparent);
    text-decoration: none;
    transition: background 150ms ease, color 150ms ease;
    min-height: 44px; /* touch target */
  }

  .nav-section-link:hover,
  .nav-section-link:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 8%, transparent);
    color: var(--color-primary, #2563eb);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* ── Active state ── */
  .nav-active {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 12%, transparent) !important;
    color: var(--color-primary, #2563eb) !important;
    font-weight: 600;
  }

  /* ── Visited indicator ── */
  .nav-visited-icon {
    flex-shrink: 0;
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-accent, #0891b2);
    font-weight: 700;
  }

  /* ── Desktop: fixed sidebar ── */
  @media (min-width: 1025px) {
    .nav-menu {
      position: sticky;
      top: 1.5rem;
      width: 260px;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
      padding: 1rem;
      background: var(--color-surface, #f8f7f4);
      border-right: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 10%, transparent);
      border-radius: 8px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-panel {
      display: block !important;
    }

    .nav-panel[aria-hidden="true"] {
      /* Always visible on desktop */
      display: block !important;
    }
  }

  /* ── Tablet (768–1024px): compact mode ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .nav-menu {
      position: sticky;
      top: 1rem;
      width: 200px;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
      padding: 0.75rem;
      background: var(--color-surface, #f8f7f4);
      border-right: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 10%, transparent);
      border-radius: 6px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-panel {
      display: block !important;
    }

    .nav-chapter-link {
      font-size: 0.8rem;
      padding: 0.4rem 0.5rem;
    }

    .nav-section-link {
      font-size: 0.75rem;
      padding: 0.3rem 0.5rem;
    }

    .nav-item-title {
      /* Truncate long titles in compact mode */
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 140px;
    }
  }

  /* ── Mobile (< 768px): hidden/collapsible ── */
  @media (max-width: 767px) {
    .nav-menu {
      position: relative;
      width: 100%;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-panel {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--color-surface, #f8f7f4);
      border: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 15%, transparent);
      border-radius: 8px;
      padding: 0.75rem;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      max-height: 70vh;
      overflow-y: auto;
    }

    .nav-panel--open {
      display: block;
    }

    .nav-section-link {
      min-height: 44px;
    }

    .nav-chapter-link {
      min-height: 44px;
    }
  }

  /* ── Category groups (Req 3.3, 5.1, 5.2) ── */
  .nav-category {
    margin-bottom: 0.125rem;
  }

  .nav-category-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.375rem 0.75rem;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    text-align: left;
    transition: background 150ms ease;
    gap: 0.25rem;
  }

  .nav-category-btn:hover,
  .nav-category-btn:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 8%, transparent);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* Req 3.3 — Category_Label visually distinct from chapter items */
  .nav-category-label {
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text, #1a1a2e) 55%, transparent);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-category-chevron {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-text, #1a1a2e) 45%, transparent);
    transition: transform 200ms ease;
    line-height: 1;
  }

  /* Req 4.3 — collapsed state hides children */
  .nav-category--collapsed > .nav-chapter-list {
    display: none;
  }

  .nav-category--collapsed .nav-category-chevron {
    transform: rotate(-90deg);
  }

  /* Req 5.1, 5.2 — active category highlight, visually different from chapter active */
  .nav-category--active > .nav-category-btn {
    background: color-mix(in srgb, var(--color-accent, #0891b2) 10%, transparent);
  }

  .nav-category--active > .nav-category-btn .nav-category-label {
    color: var(--color-accent, #0891b2);
  }

  .nav-chapter-list {
    list-style: none;
    margin: 0 0 0.25rem 0;
    padding: 0;
  }
</style>
