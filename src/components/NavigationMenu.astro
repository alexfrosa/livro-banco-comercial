---
import type { NavItem } from '../utils/contentLoader';

interface Props {
  items: NavItem[];
  currentUrl: string;
}

const { items, currentUrl } = Astro.props;

function isActive(url: string): boolean {
  return url === currentUrl;
}
---

<nav
  role="navigation"
  aria-label="Navegação do livro"
  id="navigation-menu"
  class="nav-menu"
>
  <!-- Mobile hamburger button -->
  <button
    id="nav-toggle"
    class="nav-toggle"
    aria-expanded="false"
    aria-controls="nav-panel"
    aria-label="Abrir menu de navegação"
  >
    <span class="hamburger-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <!-- Navigation panel -->
  <div id="nav-panel" class="nav-panel" aria-hidden="true">
    <ul class="nav-list" role="list">
      <li class="nav-chapter nav-home">
        <a
          href={`${import.meta.env.BASE_URL}`}
          class:list={['nav-chapter-link', { 'nav-active': currentUrl === '/' }]}
          aria-current={currentUrl === '/' ? 'page' : undefined}
        >
          <span class="nav-item-title">🏠 Home</span>
        </a>
      </li>
      {items.map((chapter) => (
        <li class="nav-chapter">
          <span
            class:list={['nav-chapter-label', { 'nav-active': isActive(chapter.url) }]}
          >
            <span class="nav-item-title">{chapter.title}</span>
          </span>

          {chapter.children && chapter.children.length > 0 && (
            <ul class="nav-section-list" role="list">
              {chapter.children.map((section) => (
                <li class="nav-section">
                  <a
                    href={`${import.meta.env.BASE_URL}${section.url}`}
                    class:list={['nav-section-link', { 'nav-active': isActive(section.url) }]}
                    aria-current={isActive(section.url) ? 'page' : undefined}
                    data-nav-url={section.url}
                    onclick="smoothScrollToSection(event, this)"
                  >
                    <span class="nav-item-title">{section.title}</span>
                    <span
                      class="nav-visited-icon"
                      aria-hidden="true"
                      data-visited-slug={section.slug}
                      style="display:none"
                    >✓</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  // Smooth scroll to section when clicking a nav item
  function smoothScrollToSection(event: MouseEvent, anchor: HTMLAnchorElement) {
    const href = anchor.getAttribute('href');
    if (!href) return;

    // Only intercept hash-based or same-page navigation
    const url = new URL(href, window.location.href);
    if (url.pathname === window.location.pathname && url.hash) {
      event.preventDefault();
      const target = document.querySelector(url.hash);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    }
  }

  // Expose for inline onclick
  (window as any).smoothScrollToSection = smoothScrollToSection;

  // Mobile hamburger toggle
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-panel');

  if (toggle && panel) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      panel.setAttribute('aria-hidden', String(expanded));
      panel.classList.toggle('nav-panel--open', !expanded);
    });
  }

  // Mark visited sections from localStorage
  function updateVisitedIndicators() {
    try {
      const raw = localStorage.getItem('ibbook_progress');
      if (!raw) return;

      const progress = JSON.parse(raw) as { visitedSections?: string[] };
      const visited = new Set(progress.visitedSections ?? []);

      document.querySelectorAll<HTMLElement>('[data-visited-slug]').forEach((el) => {
        const slug = el.getAttribute('data-visited-slug');
        if (slug && visited.has(slug)) {
          el.style.display = 'inline';
        }
      });
    } catch {
      // localStorage unavailable or corrupted — silently ignore
    }
  }

  updateVisitedIndicators();
</script>

<style>
  /* ── Base nav container ── */
  .nav-menu {
    position: relative;
  }

  /* ── Hamburger button (hidden on desktop) ── */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--color-text, #1a1a2e);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text, #1a1a2e);
    transition: background 150ms ease;
  }

  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 10%, transparent);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 20px;
  }

  .hamburger-icon span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  /* ── Nav panel ── */
  .nav-panel {
    width: 100%;
  }

  /* ── Nav list ── */
  .nav-list,
  .nav-section-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Chapter items ── */
  .nav-chapter {
    margin-bottom: 0.25rem;
  }

  .nav-chapter-link,
  .nav-chapter-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text, #1a1a2e);
    text-decoration: none;
    transition: background 150ms ease, color 150ms ease;
  }

  .nav-chapter-label {
    cursor: default;
    opacity: 0.75;
  }

  .nav-chapter-link:hover,
  .nav-chapter-link:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 8%, transparent);
    color: var(--color-primary, #2563eb);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* ── Section items ── */
  .nav-section-list {
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--color-text, #1a1a2e) 15%, transparent);
    margin: 0.125rem 0 0.25rem 0.75rem;
  }

  .nav-section-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.375rem 0.625rem;
    border-radius: 4px;
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-text, #1a1a2e) 80%, transparent);
    text-decoration: none;
    transition: background 150ms ease, color 150ms ease;
    min-height: 44px; /* touch target */
  }

  .nav-section-link:hover,
  .nav-section-link:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 8%, transparent);
    color: var(--color-primary, #2563eb);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* ── Active state ── */
  .nav-active {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 12%, transparent) !important;
    color: var(--color-primary, #2563eb) !important;
    font-weight: 600;
  }

  /* ── Visited indicator ── */
  .nav-visited-icon {
    flex-shrink: 0;
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-accent, #0891b2);
    font-weight: 700;
  }

  /* ── Desktop: fixed sidebar ── */
  @media (min-width: 1025px) {
    .nav-menu {
      position: sticky;
      top: 1.5rem;
      width: 260px;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
      padding: 1rem;
      background: var(--color-surface, #f8f7f4);
      border-right: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 10%, transparent);
      border-radius: 8px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-panel {
      display: block !important;
    }

    .nav-panel[aria-hidden="true"] {
      /* Always visible on desktop */
      display: block !important;
    }
  }

  /* ── Tablet (768–1024px): compact mode ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .nav-menu {
      position: sticky;
      top: 1rem;
      width: 200px;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
      padding: 0.75rem;
      background: var(--color-surface, #f8f7f4);
      border-right: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 10%, transparent);
      border-radius: 6px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-panel {
      display: block !important;
    }

    .nav-chapter-link {
      font-size: 0.8rem;
      padding: 0.4rem 0.5rem;
    }

    .nav-section-link {
      font-size: 0.75rem;
      padding: 0.3rem 0.5rem;
    }

    .nav-item-title {
      /* Truncate long titles in compact mode */
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 140px;
    }
  }

  /* ── Mobile (< 768px): hidden/collapsible ── */
  @media (max-width: 767px) {
    .nav-menu {
      position: relative;
      width: 100%;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-panel {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--color-surface, #f8f7f4);
      border: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 15%, transparent);
      border-radius: 8px;
      padding: 0.75rem;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      max-height: 70vh;
      overflow-y: auto;
    }

    .nav-panel--open {
      display: block;
    }

    .nav-section-link {
      min-height: 44px;
    }

    .nav-chapter-link {
      min-height: 44px;
    }
  }
</style>
