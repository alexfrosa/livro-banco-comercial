---
/**
 * BaseLayout.astro
 * Base HTML shell for all pages.
 * Requirements: 11.1, 11.2, 12.1, 12.2, 12.3, 12.4, 6.4
 */
import SkipLink from '../components/SkipLink.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import NavigationMenu from '../components/NavigationMenu.astro';
import { THEME_SCRIPT } from '../utils/themeManager';
import type { NavItem } from '../utils/contentLoader';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogUrl?: string;
  navItems: NavItem[];
  currentUrl: string;
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  ogUrl = '',
  navItems,
  currentUrl,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Anti-FOUC: apply theme before first paint (Req 6.4) -->
    <script is:inline set:html={THEME_SCRIPT}></script>

    <!-- Google Fonts (also imported in global.css for build; this preconnect speeds up load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- SEO (Req 11.1) -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (Req 11.2) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-R3WQZNE3TV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R3WQZNE3TV');
    </script>
  </head>

  <body>
    <!-- Skip link: first focusable element (Req 12.3) -->
    <!-- Also includes aria-live region for section announcements (Req 12.4) -->
    <SkipLink />

    <header class="site-header">
      <a href={`${import.meta.env.BASE_URL}`} class="site-title" aria-label="Ir para a página inicial">
        Interactive Banking Book
      </a>
      <!-- Hambúrguer: visível apenas em mobile via CSS (Bug 4 fix) -->
      <button
        id="nav-toggle"
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-panel"
        aria-label="Abrir menu de navegação"
      >
        <span class="hamburger-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
      <ThemeToggle />
    </header>

    <div class="layout">
      <!-- role="navigation" provided by NavigationMenu (Req 12.2) -->
      <NavigationMenu items={navItems} currentUrl={currentUrl} />

      <!-- role="main" landmark (Req 12.2) -->
      <main id="main-content" role="main" class="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem var(--spacing-content, 24px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 10%, transparent);
    background: var(--color-surface, #f8f7f4);
    position: sticky;
    top: 0;
    z-index: 50;
    gap: 0.5rem;
  }

  /* ── Hambúrguer (Bug 4 fix) — visível apenas em mobile ── */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 8px;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-text, #1a1a2e) 25%, transparent);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text, #1a1a2e);
    flex-shrink: 0;
    /* margin-left: auto empurra o botão para a direita, antes do ThemeToggle */
    margin-left: auto;
  }

  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    background: color-mix(in srgb, var(--color-primary, #2563eb) 10%, transparent);
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 20px;
  }

  .hamburger-icon span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  /* Ícone X quando menu está aberto (Bug 1 fix — feedback visual) */
  .nav-toggle[aria-expanded="true"] .hamburger-icon span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .nav-toggle[aria-expanded="true"] .hamburger-icon span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle[aria-expanded="true"] .hamburger-icon span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-icon span {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .nav-toggle {
      display: flex;
    }
  }

  .site-title {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text, #1a1a2e);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .site-title:hover {
    color: var(--color-accent, #4a90d9);
  }

  .layout {
    display: flex;
    min-height: calc(100vh - 56px); /* subtract header height */
    gap: 0;
  }

  .main-content {
    flex: 1;
    min-width: 0; /* prevent flex overflow */
    padding: var(--spacing-content, 24px);

    /* Fade-in transition on navigation (Req 10.11) */
    animation: fadeIn 280ms ease both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Suppress animation if user prefers reduced motion (Req 10.11) */
  @media (prefers-reduced-motion: reduce) {
    .main-content {
      animation: none;
    }
  }
</style>
