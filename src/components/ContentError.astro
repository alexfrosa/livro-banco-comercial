---
/**
 * ContentError.astro
 * Displays a descriptive error message for missing/broken content sections
 * without interrupting the rendering of other sections.
 * Requirements: 8.4
 */

interface Props {
  message: string;
  suggestion?: string;
}

const { message, suggestion } = Astro.props;
---

<div class="content-error" role="alert" aria-live="polite">
  <span class="content-error__icon" aria-hidden="true">⚠️</span>
  <div class="content-error__body">
    <p class="content-error__message">{message}</p>
    {suggestion && (
      <p class="content-error__suggestion">{suggestion}</p>
    )}
  </div>
</div>

<style>
  .content-error {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid #f87171;
    border-left: 4px solid #ef4444;
    border-radius: 6px;
    background: color-mix(in srgb, #ef4444 8%, transparent);
    margin: var(--spacing-block, 3rem) 0;
  }

  .content-error__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .content-error__body {
    flex: 1;
    min-width: 0;
  }

  .content-error__message {
    margin: 0;
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: #b91c1c;
    line-height: 1.5;
  }

  .content-error__suggestion {
    margin: 0.4rem 0 0;
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.875rem;
    color: #991b1b;
    line-height: 1.5;
  }

  [data-theme="dark"] .content-error {
    border-color: #f87171;
    border-left-color: #ef4444;
    background: color-mix(in srgb, #ef4444 12%, transparent);
  }

  [data-theme="dark"] .content-error__message {
    color: #fca5a5;
  }

  [data-theme="dark"] .content-error__suggestion {
    color: #fca5a5;
  }
</style>
