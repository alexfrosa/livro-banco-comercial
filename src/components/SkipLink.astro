---
// SkipLink.astro
// First focusable element on the page (Requirement 12.3)
// Also provides aria-live region for section announcements (Requirement 12.4)
---

<a href="#main-content" class="skip-link">Pular para o conteúdo</a>

<div
  id="section-announcer"
  aria-live="polite"
  aria-atomic="true"
  class="sr-only"
></div>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 9999;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary, #2563eb);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0 0 4px 0;
    transform: translateY(-100%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
    transform: translateY(0);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  /**
   * Exposes window.__announceSection(title) to update the aria-live region
   * so screen readers announce the new section title on navigation.
   */
  window.__announceSection = function (title: string): void {
    const announcer = document.getElementById('section-announcer');
    if (announcer) {
      // Clear first so repeated same-title navigations still trigger announcement
      announcer.textContent = '';
      // Use a small timeout to ensure the DOM update is picked up by screen readers
      setTimeout(() => {
        announcer.textContent = title;
      }, 50);
    }
  };
</script>
